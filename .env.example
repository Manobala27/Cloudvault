# CloudVault Production Environment Configuration

# Flask Application Settings
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=your_highly_secure_random_string_here
WTF_CSRF_SECRET_KEY=your_csrf_secure_random_string_here

# Database Configuration (Defaults to SQLite in instance/ if not provided)
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost/cloudvault

# AWS S3 / Compatible Object Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_production_bucket_name
S3_ENDPOINT_URL= # Leave empty for AWS S3. Use for MinIO/DigitalOcean Spaces (e.g. https://nyc3.digitaloceanspaces.com)

# Gunicorn / App Server Settings
PORT=5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# Application Limits
MAX_CONTENT_LENGTH=10485760 # Max upload size in bytes (10MB default)

# Security (For HTTPS / Production)
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
